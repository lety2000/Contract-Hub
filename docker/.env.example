# ============================================
# Vertragsmanager - Umgebungsvariablen
# ============================================
# Kopiere diese Datei nach .env und passe die Werte an!
# cp .env.example .env

# Port auf dem die App läuft (für Reverse Proxy)
# Dieser Port wird von Nginx/Synology Reverse Proxy angesteuert
PORT=8080

# Externe URL (optional, wird für einige Features benötigt)
# Beispiel: https://vertragsmanager.deine-domain.de
# Wenn leer, werden relative URLs verwendet
EXTERNAL_URL=

# JWT Secret - UNBEDINGT ÄNDERN!
# Generiere ein sicheres Passwort, z.B. mit: openssl rand -base64 32
JWT_SECRET=dein-geheimes-jwt-passwort-hier-aendern

# ============================================
# E-Mail Einstellungen (Gmail SMTP)
# ============================================
# Diese können auch später in der App geändert werden!

# Gmail SMTP Server
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Deine Gmail-Adresse
SMTP_USER=deine.email@gmail.com

# Gmail App-Passwort (NICHT dein normales Passwort!)
# Erstelle es hier: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=dein-app-passwort

# Absender E-Mail (normalerweise gleich wie SMTP_USER)
SMTP_FROM_EMAIL=deine.email@gmail.com

# Absender Name
SMTP_FROM_NAME=Vertragsmanager
